<!-- Announcement Topbar -->
{% if theme.settings.get('luxe_show_topbar') %}
<div class="announcement-bar" id="announcementBar">
  <div class="container">
    <p>{{ theme.settings.get('luxe_topbar_text') }}</p>
    <button class="announcement-bar__close" onclick="document.getElementById('announcementBar').style.display='none'">✕</button>
  </div>
</div>
{% endif %}

<header class="site-header{% if not theme.settings.get('header_is_sticky', true) %} site-header--static{% endif %}">
  <div class="container header-inner">
    <!-- Hamburger for mobile -->
    <button class="hamburger" id="mobileMenuBtn" aria-label="{{ 'header.menu' | trans }}">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="logo">
      {% if store.logo %}
        <img src="{{ store.logo }}" alt="{{ store.name }}">
      {% else %}
        <h2 class="store-name">{{ store.name }}</h2>
      {% endif %}
    </a>

    <!-- Navigation Desktop: من «قوائم Header» في تخصيص الثيم، أو تصنيفات المتجر كاحتياطي -->
    <nav class="nav-desktop">
      {% hook 'component:header.menu.start' %}
      {% component 'header.menu' %}
      {% hook 'component:header.menu.end' %}
    </nav>

    <!-- Header Actions -->
    <div class="header-actions">
      {% if theme.settings.get('luxe_header_show_search', true) %}
      <div class="search-wrap">
        <salla-search></salla-search>
      </div>
      {% endif %}
      
      {% if theme.settings.get('luxe_header_show_account', true) %}
      <salla-login-button></salla-login-button>
      {% endif %}

      {% if theme.settings.get('luxe_header_show_wishlist', true) %}
      <a href="/wishlist" class="action-btn" aria-label="{{ 'product.wishlist' | trans }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.78-8.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </a>
      {% endif %}

      <button class="action-btn cart-toggle" id="cartToggleBtn" aria-label="{{ 'cart.title' | trans }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="cart-count" id="cartCountBadge">{{ cart.count }}</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Sidebar -->
<div class="mobile-sidebar" id="mobileSidebar">
  <div class="mobile-sidebar__header">
    <span class="logo-small">{{ store.name }}</span>
    <button id="closeMobileMenu">✕</button>
  </div>
  <nav class="mobile-nav">
    <ul>
      {% if menus is defined and menus|length > 0 %}
        <li><a href="/">{{ 'general.home' | trans }}</a></li>
        {% for menu in menus %}
          <li>
            <a href="{{ menu.url }}">{{ menu.title }}</a>
          </li>
          {% if menu.has_children %}
            {% for submenu in menu.children %}
              <li class="mobile-nav__sub">
                <a href="{{ submenu.url }}">{{ submenu.title }}</a>
              </li>
            {% endfor %}
          {% endif %}
        {% endfor %}
      {% else %}
        <li><a href="/">{{ 'general.home' | trans }}</a></li>
        {% for category in categories %}
          <li><a href="{{ category.url }}">{{ category.name }}</a></li>
        {% endfor %}
      {% endif %}
    </ul>
  </nav>
</div>
<div class="mobile-sidebar-overlay" id="mobileSidebarOverlay"></div>
