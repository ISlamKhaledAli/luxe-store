{#
| Variable                       | Type    | Description                                                                  |
|--------------------------------|---------|------------------------------------------------------------------------------|
| component                      | object  | Contains merchant settings for fields from twilight.json `component` section |
| component.brands               | Brand[] | list of selected brands @see views/pages/brands/single.twig                  |
| position                       | int     | Sorting number start from zero                                               |
#}
<section class="luxe-section luxe-section--brands">
    <div class="luxe-container">
        {% set brand_title = component.title %}
        {% if brand_title is iterable %}{% set brand_title = brand_title.ar|default(brand_title.en|default('')) %}{% endif %}
        {% if brand_title %}
          <div class="luxe-section__head">
            <h2>{{ brand_title }}</h2>
          </div>
        {% endif %}

        <div class="luxe-brands-grid">
            {% for brand in component.brands %}
                {% set logo_src = brand.logo.url|default(brand.logo|default('')) %}
                <a href="{{ brand.url }}" class="luxe-brand-card">
                    {% if logo_src %}
                    <img loading="lazy" src="{{ logo_src }}" alt="{{ brand.name }}"/>
                    {% else %}
                    <span class="luxe-brand-card__name">{{ brand.name }}</span>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    </div>
</section>
