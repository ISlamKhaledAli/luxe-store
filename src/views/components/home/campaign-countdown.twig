{#
| حملة ترويجية مع عدّاد تنازلي |
#}
{% set mode = 'standard' %}
{% if component.is_compact %}
  {% set mode = 'compact' %}
{% endif %}
<section class="luxe-campaign luxe-promo-banner luxe-promo-banner--{{ mode }}" data-reveal
         {% if component.image %}style="--promo-bg: url('{{ component.image | e('html_attr') }}');"{% endif %}>
  <div class="luxe-promo-banner__bg" role="img" aria-hidden="true"></div>
  <div class="luxe-promo-banner__overlay"></div>
  <div class="luxe-container luxe-promo-banner__inner luxe-campaign__inner">
    {% if component.badge %}
      <p class="luxe-promo-banner__eyebrow">{{ component.badge }}</p>
    {% endif %}
    <h2 class="luxe-promo-banner__title">{{ component.title }}</h2>
    {% if component.subtitle %}
      <p class="luxe-promo-banner__subtitle">{{ component.subtitle }}</p>
    {% endif %}
    {% if component.show_countdown and component.end_at %}
      <div class="luxe-campaign__timer" data-luxe-campaign-end="{{ component.end_at|e('html_attr') }}" aria-label="{{ 'home.flash_sale'|trans|default('ينتهي العرض') }}">
        <div class="luxe-campaign__t-unit">
          <span class="luxe-campaign__t-val" data-part="d">00</span>
          <span class="luxe-campaign__t-label">يوم</span>
        </div>
        <div class="luxe-campaign__t-unit">
          <span class="luxe-campaign__t-val" data-part="h">00</span>
          <span class="luxe-campaign__t-label">ساعة</span>
        </div>
        <div class="luxe-campaign__t-unit">
          <span class="luxe-campaign__t-val" data-part="m">00</span>
          <span class="luxe-campaign__t-label">دقيقة</span>
        </div>
        <div class="luxe-campaign__t-unit">
          <span class="luxe-campaign__t-val" data-part="s">00</span>
          <span class="luxe-campaign__t-label">ثانية</span>
        </div>
      </div>
    {% endif %}
    {% set _btn = component.btn_url %}
{% if _btn is iterable %}
  {% set _btn = '' %}
{% endif %}
{% if component.btn_text and _btn %}
      <a href="{{ _btn }}" class="btn btn--primary luxe-promo-banner__btn">{{ component.btn_text }}</a>
    {% endif %}
  </div>
</section>
