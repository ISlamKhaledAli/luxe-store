{#
| شبكة منتجات مميزة — اختيار يدوي من المتجر
#}

{% set products = component.products|default([]) %}
{% set heading = component.heading %}
{% if heading is iterable %}{% set heading = heading.ar|default(heading.en|default('')) %}{% endif %}

<section class="luxe-section luxe-feat-grid" data-reveal>
  <div class="luxe-container">
    <header class="luxe-section__head">
      <h2>{{ heading|default('منتجات مختارة') }}</h2>
      
      {% set sub = component.subheading %}
      {% if sub is iterable %}{% set sub = sub.ar|default(sub.en|default('')) %}{% endif %}
      {% if sub %}
        <p class="luxe-feat-grid__lead">{{ sub }}</p>
      {% endif %}
    </header>

    {% if products|length %}
      <div class="luxe-feat-grid__products products-grid">
        {% for product in products %}
          {% component 'product-card.product-card' with { product: product } %}
        {% endfor %}
      </div>
    {% else %}
      <div class="luxe-feat-grid__slider">
        {# Fallback: If no products, show latest products using Salla component #}
        <salla-products-slider source="latest" block-title=" " slider-id="fallback-{{ position }}"></salla-products-slider>
      </div>
    {% endif %}

    {% set url = component.display_all_url %}
    {% if url is iterable and url|length > 0 %}
      {% set _u = url|first %}
      {% set url = _u.url is defined ? _u.url : (_u is iterable ? '' : _u) %}
    {% elseif url.url is defined %}
      {% set url = url.url %}
    {% endif %}
    {% if url is iterable %}{% set url = '' %}{% endif %}

    {% if url and url != '#' %}
      <div class="luxe-feat-grid__actions">
        <a href="{{ url }}" class="btn btn--secondary">عرض الكل</a>
      </div>
    {% endif %}
  </div>
</section>
