{#
| شبكة منتجات مميزة — اختيار يدوي من المتجر
| component.products Product[]
#}

{% set display_all = component.display_all_url %}
{# Salla handles variable-list/items source differently, we need to extract the URL safely #}
{% if display_all is iterable and display_all|length > 0 %}
    {% set display_all = display_all|first.url|default(display_all|first) %}
{% endif %}
{% if display_all is iterable %}{% set display_all = '' %}{% endif %}

<section class="luxe-section luxe-feat-grid" data-reveal>
  <div class="luxe-container">
    <header class="luxe-section__head">
      {# Safe handling for multilanguage heading #}
      {% set heading = component.heading %}
      {% if heading is iterable %}
        {% set heading = heading.ar|default(heading.en|default('')) %}
      {% endif %}
      <h2>{{ heading|default(trans('blocks.home.featured_products')) }}</h2>

      {# Safe handling for multilanguage subheading #}
      {% set subheading = component.subheading %}
      {% if subheading is iterable %}
        {% set subheading = subheading.ar|default(subheading.en|default('')) %}
      {% endif %}
      {% if subheading %}
        <p class="luxe-feat-grid__lead">{{ subheading }}</p>
      {% endif %}
    </header>

    {% if component.products|default([])|length %}
      <div class="luxe-feat-grid__products products-grid">
        {% for product in component.products %}
          {% component 'product-card.product-card' with { product: product } %}
        {% endfor %}
      </div>
    {% else %}
      <div class="luxe-feat-grid__slider">
        {# fallback if no products selected: show latest #}
        <salla-products-slider
          source="latest"
          block-title=" "
          slider-id="luxe-feat-fallback-{{ position }}"
        ></salla-products-slider>
      </div>
    {% endif %}

    {% if display_all and display_all != '' and display_all != '#' %}
      <div class="luxe-feat-grid__actions">
        <a href="{{ display_all }}" class="btn btn--secondary">عرض الكل</a>
      </div>
    {% endif %}
  </div>
</section>
