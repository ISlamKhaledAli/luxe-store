{#
| شبكة منتجات مميزة — اختيار يدوي من المتجر |
| component.products Product[] |
#}
{% set display_all = component.display_all_url %}
{% if display_all is iterable %}
  {% set display_all = '' %}
{% endif %}
<section class="luxe-section luxe-feat-grid" data-reveal>
  <div class="luxe-container">
    <header class="luxe-section__head">
      <h2>{{ component.heading }}</h2>
      {% if component.subheading %}
        <p class="luxe-feat-grid__lead">{{ component.subheading }}</p>
      {% endif %}
    </header>
    {% if component.products|length %}
      <div class="luxe-feat-grid__products products-grid">
        {% for product in component.products %}
          {% component 'product-card.product-card' with { product: product } %}
        {% endfor %}
      </div>
      {% if display_all and display_all != '' and display_all != '#' %}
        <div class="luxe-feat-grid__actions">
          <a href="{{ display_all }}" class="btn btn--secondary">عرض الكل</a>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>
