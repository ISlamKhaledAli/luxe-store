{#
| Variable | Type | Description |
| component | object | إعدادات المكوّن من twilight.json |
| component.items[] / items[] | array | صفوف المعرض — أحياناً تُمرَّر items جذرياً (مثل store-features) |
| position | int | ترتيب المكوّن |
| نفس أسلوب home.custom-testimonials — تسطيح سلة أو مفاتيح items.* |
#}
{% set rows = items is defined ? items|default([]) : component.items|default([]) %}
{% if rows|length > 0 %}
<section id="luxe-gallery-{{ position|default(0) }}" class="luxe-section luxe-gallery-block" data-reveal>
  <div class="luxe-container">
    <div class="luxe-section__head">
      {% set h = component.heading|default('') %}
      {% if h is iterable %}{% set h = h.ar|default(h.en|default('')) %}{% endif %}
      <h2>{{ h|default('معرض الصور') }}</h2>
    </div>

    {% set four = component.use_four_columns|default(false) %}
    <div class="luxe-gallery-block__grid {{ four ? 'luxe-gallery-block__grid--4' : 'luxe-gallery-block__grid--3' }}">
      {% for item in rows %}
        {% set pic = item.image|default(item['items.image']|default('')) %}
        {% if pic.url is defined and pic.url %}
          {% set pic = pic.url %}
        {% elseif pic.thumbnail is defined and pic.thumbnail %}
          {% set pic = pic.thumbnail %}
        {% elseif pic.path is defined and pic.path %}
          {% set pic = pic.path %}
        {% endif %}

        {% set cap = item.caption|default(item['items.caption']|default('')) %}
        {% if cap is iterable %}{% set cap = cap.ar|default(cap.en|default('')) %}{% endif %}

        {% set link = item.url|default(item['items.url']|default('')) %}
        {% if link is iterable %}{% set link = link.ar|default(link.en|default('')) %}{% endif %}
        {% set link = (link ~ '')|trim %}

        {% if pic %}
          {% if link %}
          <a href="{{ link }}" class="luxe-gallery-block__cell">
          {% else %}
          <div class="luxe-gallery-block__cell">
          {% endif %}
            <div class="luxe-gallery-block__media">
              <img src="{{ pic }}" alt="{{ cap|default('') }}" loading="lazy" decoding="async">
              <span class="luxe-gallery-block__shine" aria-hidden="true"></span>
            </div>
            {% if cap %}
            <span class="luxe-gallery-block__cap">{{ cap }}</span>
            {% endif %}
          {% if link %}
          </a>
          {% else %}
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
