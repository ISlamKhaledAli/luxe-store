{#
  معرض صور Luxe
  - المجموعة id: gallery (تجنّب تعارض اسم items مع منصة سلة/Twig)
  - يدعم مفاتيح مسطّحة gallery.* أو متداخل item.gallery.*
  - صورة من نوع image في سلة: url / full_url / source / نص مباشر

  https://salla.dev/blog/image-preview-for-salla-themes-components/
#}
{% set rows = component.gallery|default([]) %}
{% if rows|length == 0 %}
  {% set rows = component.items|default([]) %}
{% endif %}
{% if rows|length == 0 and gallery is defined and gallery is iterable %}
  {% set rows = gallery %}
{% endif %}
{% if rows|length == 0 and items is defined and items is iterable %}
  {% set rows = items %}
{% endif %}
{% if rows is not iterable %}
  {% set rows = [] %}
{% endif %}

{% if rows|length > 0 %}
<section id="luxe-gallery-{{ position }}" class="luxe-section luxe-gallery-block" data-reveal>
  <div class="luxe-container">
    {% set title = component.heading|default('') %}
    {% if title is iterable %}
      {% set title = title.ar|default(title.en|default('')) %}
    {% endif %}
    {% if title %}
    <header class="luxe-section__head">
      <h2>{{ title }}</h2>
    </header>
    {% endif %}

    {% set four = component.use_four_columns|default(false) %}
    <div class="luxe-gallery-block__grid {{ four ? 'luxe-gallery-block__grid--4' : 'luxe-gallery-block__grid--3' }}">
      {% for item in rows %}
        {% set nest = item.gallery|default(item.items|default(null)) %}

        {% set raw = item.image|default(item['gallery.image']|default(item['items.image']|default(''))) %}
        {% if not raw and nest is not null and nest.image is defined %}
          {% set raw = nest.image %}
        {% endif %}

        {% set src = '' %}
        {% if raw %}
          {% if raw.url is defined and raw.url %}
            {% set src = raw.url %}
          {% elseif raw.full_url is defined and raw.full_url %}
            {% set src = raw.full_url %}
          {% elseif raw.source is defined and raw.source %}
            {% set src = raw.source %}
          {% elseif raw.path is defined and raw.path %}
            {% set src = raw.path %}
          {% elseif raw is iterable and raw|length > 0 and raw.ar is not defined %}
            {% set _f = raw|first %}
            {% if _f.url is defined and _f.url %}
              {% set src = _f.url %}
            {% elseif _f is not iterable %}
              {% set src = _f %}
            {% endif %}
          {% else %}
            {% set src = raw %}
          {% endif %}
        {% endif %}
        {% if src is iterable %}{% set src = '' %}{% endif %}

        {% set cap = item.caption|default(item['gallery.caption']|default(item['items.caption']|default(''))) %}
        {% if not cap and nest is not null and nest.caption is defined %}
          {% set cap = nest.caption %}
        {% endif %}
        {% if cap is iterable %}
          {% set cap = cap.ar|default(cap.en|default('')) %}
        {% endif %}

        {% set href = item.url|default(item['gallery.url']|default(item['items.url']|default(''))) %}
        {% if not href and nest is not null and nest.url is defined %}
          {% set href = nest.url %}
        {% endif %}
        {% if href is iterable %}
          {% set href = href.ar|default(href.en|default('')) %}
        {% endif %}
        {% set href = (href ~ '')|trim %}

        {% set alt = '' %}
        {% if raw and raw.alt is defined and raw.alt %}
          {% set alt = raw.alt %}
        {% endif %}
        {% if raw and not alt and raw.title is defined and raw.title %}
          {% set alt = raw.title %}
        {% endif %}
        {% if not alt and cap %}
          {% set alt = cap %}
        {% endif %}

        {% if src %}
          {% if href %}
          <a href="{{ href }}" class="luxe-gallery-block__cell">
          {% else %}
          <div class="luxe-gallery-block__cell">
          {% endif %}
            <div class="luxe-gallery-block__media">
              <img src="{{ src }}" alt="{{ alt }}" loading="lazy" decoding="async">
              <span class="luxe-gallery-block__shine" aria-hidden="true"></span>
            </div>
            {% if cap %}
            <span class="luxe-gallery-block__cap">{{ cap }}</span>
            {% endif %}
          {% if href %}
          </a>
          {% else %}
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
