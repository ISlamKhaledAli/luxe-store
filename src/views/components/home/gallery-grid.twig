{#
  معرض صور — يطابق أسلوب Twilight: collection بحقول بسيطة (image, caption, url)
  وطبقة الصور item.image.url كما في توثيق Photos slider.

  | Variable | Type | Description |
  | component.heading | ?string | عنوان القسم |
  | component.use_four_columns | bool | أربع أعمدة |
  | component.items[] | array | الصور |
  | component.items[].image | string|{url, alt} | الصورة |
  | component.items[].caption | ?string | وصف (متعدد اللغات اختياري) |
  | component.items[].url | ?string | رابط اختياري |
  | position | int | ترتيب المكوّن |

  مراجع: https://docs.salla.dev/421921m0 — https://docs.salla.dev/doc-422586
  دليل Twilight: https://salla.dev/blog/all-in-one-twilight-guide-for-salla-developers/
#}
{% set rows = component.items|default([]) %}
{% if rows|length == 0 and items is defined and items is iterable %}
  {% set rows = items %}
{% endif %}
{% if rows is not iterable %}
  {% set rows = [] %}
{% endif %}

{% if rows|length > 0 %}
<section id="luxe-gallery-{{ position }}" class="luxe-section luxe-gallery-block" data-reveal>
  <div class="luxe-container">
    {% set title = component.heading|default('') %}
    {% if title is iterable %}
      {% set title = title.ar|default(title.en|default('')) %}
    {% endif %}
    {% if title %}
    <header class="luxe-section__head">
      <h2>{{ title }}</h2>
    </header>
    {% endif %}

    {% set four = component.use_four_columns|default(false) %}
    <div class="luxe-gallery-block__grid {{ four ? 'luxe-gallery-block__grid--4' : 'luxe-gallery-block__grid--3' }}">
      {% for item in rows %}
        {% set img = item.image|default('') %}
        {% set src = img.url is defined ? img.url : img %}
        {% set alt = img.alt is defined ? img.alt : '' %}

        {% set cap = item.caption|default('') %}
        {% if cap is iterable %}
          {% set cap = cap.ar|default(cap.en|default('')) %}
        {% endif %}
        {% if not alt and cap %}
          {% set alt = cap %}
        {% endif %}

        {% set href = item.url|default('') %}
        {% if href is iterable %}
          {% set href = href.ar|default(href.en|default('')) %}
        {% endif %}
        {% set href = (href ~ '')|trim %}

        {% if src %}
          {% if href %}
          <a href="{{ href }}" class="luxe-gallery-block__cell">
          {% else %}
          <div class="luxe-gallery-block__cell">
          {% endif %}
            <div class="luxe-gallery-block__media">
              <img src="{{ src }}" alt="{{ alt }}" loading="lazy" decoding="async">
              <span class="luxe-gallery-block__shine" aria-hidden="true"></span>
            </div>
            {% if cap %}
            <span class="luxe-gallery-block__cap">{{ cap }}</span>
            {% endif %}
          {% if href %}
          </a>
          {% else %}
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
