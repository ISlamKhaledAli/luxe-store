{#
  معرض صور — حقول المجموعة بصيغة سلة: items.image / items.caption / items.url
  (نفس أسلوب slides.* في الثيمات الرسمية و items.* في الـ testimonials)

  | component.items[] | عناصر المجموعة id: items في twilight.json |
  | component.items[].items.image | أو مفتاح مسطح items.image على كل عنصر |

  معاينة المكوّن في لوحة الثيم: مفتاح "image" على المكوّن في twilight.json
  https://salla.dev/blog/image-preview-for-salla-themes-components/
#}
{% set rows = component.items|default([]) %}
{% if rows|length == 0 and items is defined and items is iterable %}
  {% set rows = items %}
{% endif %}
{% if rows is not iterable %}
  {% set rows = [] %}
{% endif %}

{% if rows|length > 0 %}
<section id="luxe-gallery-{{ position }}" class="luxe-section luxe-gallery-block" data-reveal>
  <div class="luxe-container">
    {% set title = component.heading|default('') %}
    {% if title is iterable %}
      {% set title = title.ar|default(title.en|default('')) %}
    {% endif %}
    {% if title %}
    <header class="luxe-section__head">
      <h2>{{ title }}</h2>
    </header>
    {% endif %}

    {% set four = component.use_four_columns|default(false) %}
    <div class="luxe-gallery-block__grid {{ four ? 'luxe-gallery-block__grid--4' : 'luxe-gallery-block__grid--3' }}">
      {% for item in rows %}
        {% set row = item.items|default(null) %}

        {% set raw = item.image|default(item['items.image']|default('')) %}
        {% if not raw and row is not null and row.image is defined %}
          {% set raw = row.image %}
        {% endif %}

        {% set src = '' %}
        {% if raw %}
          {% if raw.url is defined %}
            {% set src = raw.url %}
          {% elseif raw is iterable and raw|length > 0 %}
            {% set _first = raw|first %}
            {% set src = _first.url is defined ? _first.url : (_first is iterable ? '' : _first) %}
          {% else %}
            {% set src = raw %}
          {% endif %}
        {% endif %}

        {% set cap = item.caption|default(item['items.caption']|default('')) %}
        {% if not cap and row is not null and row.caption is defined %}
          {% set cap = row.caption %}
        {% endif %}
        {% if cap is iterable %}
          {% set cap = cap.ar|default(cap.en|default('')) %}
        {% endif %}

        {% set href = item.url|default(item['items.url']|default('')) %}
        {% if not href and row is not null and row.url is defined %}
          {% set href = row.url %}
        {% endif %}
        {% if href is iterable %}
          {% set href = href.ar|default(href.en|default('')) %}
        {% endif %}
        {% set href = (href ~ '')|trim %}

        {% set alt = '' %}
        {% if raw and raw.alt is defined %}
          {% set alt = raw.alt %}
        {% endif %}
        {% if not alt and cap %}
          {% set alt = cap %}
        {% endif %}

        {% if src %}
          {% if href %}
          <a href="{{ href }}" class="luxe-gallery-block__cell">
          {% else %}
          <div class="luxe-gallery-block__cell">
          {% endif %}
            <div class="luxe-gallery-block__media">
              <img src="{{ src }}" alt="{{ alt }}" loading="lazy" decoding="async">
              <span class="luxe-gallery-block__shine" aria-hidden="true"></span>
            </div>
            {% if cap %}
            <span class="luxe-gallery-block__cap">{{ cap }}</span>
            {% endif %}
          {% if href %}
          </a>
          {% else %}
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
