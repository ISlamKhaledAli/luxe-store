{#
| Pillars: icon, title, text |
#}
<section class="luxe-section luxe-why" data-reveal>
  <div class="luxe-container">
    <header class="luxe-section__head">
      <h2>{{ component.heading }}</h2>
      {% if component.subheading %}
        <p class="luxe-why__lead">{{ component.subheading }}</p>
      {% endif %}
    </header>
    <div class="luxe-why__grid">
      {% for item in component.pillars %}
        {% set ic = item.icon|default(item['pillars.icon']|default('sicon-star')) %}
        {% set ttl = item.title|default(item['pillars.title']|default('')) %}
        {% set body = item.text|default(item['pillars.text']|default('')) %}
        <article class="luxe-why__card glass-card" data-reveal>
          <div class="luxe-why__icon" aria-hidden="true">
            <i class="{{ ic }}"></i>
          </div>
          <h3>{{ ttl }}</h3>
          <p>{{ body }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
