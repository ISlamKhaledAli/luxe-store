{% extends "layouts.master" %}

{% set hero_t = theme.settings.get('luxe_hero_title', 'روائح تروي قصتك') %}
{% set hero_s = theme.settings.get('luxe_hero_subtitle', 'تشكيلة مختارة من أرقى بيوت العطور — ثبات وأناقة في كل رشة') %}
{% set hero_img = theme.settings.get('luxe_hero_image', 'https://images.unsplash.com/photo-1595425970377-c970070d5a7d?auto=format&fit=crop&q=85&w=1920') %}
{% set hero_cta = theme.settings.get('luxe_hero_cta_text', 'تسوق الآن') %}
{% set hero_url = theme.settings.get('luxe_hero_cta_url', '/store') %}

{% set luxe_skip_static_hero = false %}
{% if page.components|default([])|length %}
  {% set _fc = page.components|first %}
  {% if _fc.path is defined and _fc.path == 'home.enhanced-slider' and not theme.settings.get('luxe_force_home_static_hero', false) %}
    {% set luxe_skip_static_hero = true %}
  {% endif %}
{% endif %}

{% block content %}
<article class="home-page">
  <!-- ① HERO SECTION (يُخفى تلقائياً إذا كان أول عنصر «سلايدر عرض العطور») -->
  {% if not luxe_skip_static_hero %}
  <section class="hero" style="background-image: url('{{ hero_img }}')">
    <div class="hero-content">
      <h1>{{ hero_t }}</h1>
      {% if hero_s %}
        <p>{{ hero_s }}</p>
      {% endif %}
      <div class="hero-btns">
        <a href="{{ hero_url }}" class="btn btn--primary">{{ hero_cta }}</a>
        <a href="/store" class="btn btn--secondary">استكشف العطور</a>
      </div>
    </div>
    <div class="hero-shape shape-1"></div>
    <div class="hero-shape shape-2"></div>
  </section>
  {% endif %}

  <!-- ② الصفحة الرئيسية من مُنشِّئ سلة — يجب استخدام {% component home %} حتى تُعرض العناصر التي تضيفها من لوحة الثيم -->
  <div class="luxe-dynamic-sections">
    {% component home %}
  </div>

  <!-- ③ DEFAULT SECTIONS (Fallback/Fixed) -->
  {% if page.components|default([])|length == 0 %}
    <section class="featured-categories container">
      <div class="section-title">
        <h2>تسوق حسب الفئة</h2>
      </div>
      <div class="categories-grid">
        {% for category in categories | slice(0, 8) %}
          <a href="{{ category.url }}" class="category-card" data-reveal>
            <div class="category-card__image">
              <img loading="lazy" src="{{ category.image.url }}" alt="{{ category.name }}">
            </div>
            <span class="category-card__name">{{ category.name }}</span>
          </a>
        {% endfor %}
      </div>
    </section>

    <section class="featured-products container">
      <div class="section-title">
        <h2>منتجاتنا المختارة</h2>
        <p>أرقى التشكيلات التي تناسب ذوقك الرفيع</p>
      </div>
      <div class="products-grid">
        {% for product in products | slice(0, 8) %}
          {% component 'product-card.product-card' with { product: product } %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <!-- ④ RECENTLY VIEWED -->
  <section class="recently-viewed container" id="recentlyViewedSection" style="display:none;">
    <div class="section-title">
      <h2>شاهدتها مؤخراً</h2>
    </div>
    <div class="products-grid" id="recentlyViewedContainer"></div>
  </section>
</article>

<style>
.hero-shape {
  position: absolute;
  background: var(--glass-bg);
  backdrop-filter: blur(5px);
  border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
  z-index: 0;
}
.shape-1 { width: 200px; height: 200px; top: 10%; left: 5%; }
.shape-2 { width: 150px; height: 150px; bottom: 15%; right: 10%; }
</style>
{% endblock %}
